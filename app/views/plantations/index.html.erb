<body>
<p id="notice"><%= notice %></p>
<main role="main" class="col-md-9 ml-sm-auto col-lg-10 pt-3 px-4">
          <div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pb-2 mb-3 border-bottom">
            <h1 class="h2">Plantations</h1>
            <div class="btn-toolbar mb-2 mb-md-0">
              <div class="btn-group mr-2">
                <button class="btn btn-sm btn-outline-secondary">Share</button>
                <button class="btn btn-sm btn-outline-secondary">Export</button>
              </div>
            </div>
            
          </div>
<p id="notice"><%= notice %></p>

<div class="container">
<div>
<%= link_to 'New Plantation', new_plantation_path,:class => "button btn btn-success"  %>
</div>
<br/>
<table class="table table-hover table-bordered table-sm">
  <thead>
    <tr>
      <th>Name</th>
      <th>Description</th>
      <th>Coordinates</th>
      <th>Town</th>
      <th>Barangay</th>
      <th>Zone</th>
      <th>Planter</th>
      <th colspan="3"></th>
    </tr>
  </thead>

  <tbody>
    <% @plantations.each do |plantation| %>
      <tr>
        <td><%= plantation.name %></td>
        <td><%= plantation.description %></td>
        <td><%= plantation.coordinates %></td>
        <td><%= plantation.area.town %></td>
        <td><%= plantation.area.barangay %></td>
        <td><%= plantation.area.zone %></td>
        <td><%= link_to plantation.planter.name, planter_path(plantation.planter)%></td>
        <td><%= link_to 'Show', plantation %></td>
        <td><%= link_to 'Edit', edit_plantation_path(plantation) %></td>
        <td><%= link_to 'Destroy', plantation, method: :delete, data: { confirm: 'Are you sure?' } %></td>
      </tr>
    <% end %>
  </tbody>
</table>

<br>
</div>
</body>