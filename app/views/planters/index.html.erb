<div class="container">
<p id="notice"><%= notice %></p>

<h1>Planters</h1>

<table class="table table-hover table-bordered">
  <thead>
    <tr>
      <th>Name</th>
      <th>Address</th>
      <th>Contact no</th>
      <th colspan="3"></th>
    </tr>
  </thead>

  <tbody>
    <% @planters.each do |planter| %>
      <tr>
        <td><%= planter.name %></td>
        <td><%= planter.address %></td>
        <td><%= planter.contact_no %></td>
        <td><%= link_to 'Show', planter %></td>
        <td><%= link_to 'Edit', edit_planter_path(planter) %></td>
        <td><%= link_to 'Destroy', data: { confirm: 'Are you sure?' } %></td>
      </tr>
    <% end %>
  </tbody>
</table>

<br>

<%= link_to 'New Planter', new_planter_path,:class => "button btn btn-success"  %>
</div>