<div class="container">
<p id="notice"><%= notice %></p>
<div>
<h1>Areas</h1>

<table class="table table-hover table-bordered">
  <thead>
    <tr>
      <th>Town</th>
      <th>Barangay</th>
      <th>Zone</th>
      <th>Km distance</th>
      <th>Fuel</th>
      <th colspan="3"></th>
    </tr>
  </thead>
</div>
  <tbody>
    <% @areas.each do |area| %>
      <tr>
        <td><%= area.town %></td>
        <td><%= area.barangay %></td>
        <td><%= area.zone %></td>
        <td><%= area.km_distance %></td>
        <td><%= area.fuel %></td>
        <td><%= link_to 'Show', area %></td>
        <td><%= link_to 'Edit', edit_area_path(area) %></td>
        <td><%= link_to 'Destroy', area, method: :delete, data: { confirm: 'Are you sure?' } %></td>
      </tr>
    <% end %>
  </tbody>
</table>

<br>

<%= link_to 'New Area', new_area_path ,:class => "button btn btn-success"  %>
</div>